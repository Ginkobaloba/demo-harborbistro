# Stripe (chunk 3.7). Test mode only.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Paradigm Portal federation (chunk 4b).
# See portal-shell/docs/PORTAL_GATE_CONTRACT.md.
PORTAL_JWKS_URL=https://portal.projectnexuscode.org/.well-known/jwks.json
PORTAL_EXPECTED_ISSUER=https://portal.projectnexuscode.org
PORTAL_EXPECTED_AUD=harborbistro

# App-side session cookie secret. At least 32 chars of high-entropy random.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=replace-with-48-bytes-of-random
